# Copy to .env and fill in. .env is gitignored.

# Transkribus account (readcoop SSO login, used for the Metagrapho API)
TRANSKRIBUS_USER=
TRANSKRIBUS_PASSWORD=

# Optional recognition defaults (Metagrapho model IDs from the Transkribus model catalogue)
# TRANSKRIBUS_HTR_ID=
# TRANSKRIBUS_LINE_MODEL_ID=
# TRANSKRIBUS_LANGUAGE_MODEL=built-in
